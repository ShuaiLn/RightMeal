# RightMeal API keys — all optional. The app works fully without any of them
# (prices fall back to BLS regional averages and curated seed estimates).
# Copy this file to .env and fill in the keys you have.

# Kroger Products API (https://developer.kroger.com) — real store prices
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# Instacart Developer Platform — product matching + numeric prices
INSTACART_API_KEY=

# USDA FoodData Central (https://fdc.nal.usda.gov/api-guide)
# Used ONLY by dev-time tools (tools/import_usda_foods.py) to fetch nutrition
# candidates for new catalog ingredients. Never packaged; the app reads the
# reviewed local JSON (extended_foods.json) and never calls USDA at runtime.
FDC_API_KEY=

# OpenAI — optional explanations, cooking steps, leftover estimates, and
# evidence-only product/receipt photo extraction. Photo catalog matching remains local.
OPENAI_API_KEY=

# BLS Public Data API (https://www.bls.gov/developers/) — optional, raises rate limits
BLS_API_KEY=
